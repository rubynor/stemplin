<% content_for :title, t("common.shared_with") %>

<div class="flex flex-col gap-y-8">
  <div class="flex flex-row justify-between items-center border-b border-gray-100 py-3">
    <div class="flex flex-row items-center gap-x-2">
      <span class="font-medium text-gray-600 text-lg"><%= t("common.shared_with") %></span>
    </div>
    <div class="flex flex-row gap-2">
      <%= render ButtonComponent.new(path: workspace_project_path(@project), method: :get, variant: :outline) do %>
        <span class="hidden lg:block mr-2"><%= t("common.back_to_project") %></span>
        <i class="uc-icon">&#xe833;</i>
      <% end %>
    </div>
  </div>

  <div class="divide-y divide-gray-100 flex flex-col">
    <% if @project_shares.any? %>
      <% @project_shares.each do |project_share| %>
        <div class="text-sm text-gray-600 flex justify-between items-center w-full py-4">
          <span class="font-semibold"><%= project_share.organization.name %></span>
          <%= render ButtonComponent.new(
            path: workspace_project_project_share_path(@project, project_share),
            method: :delete,
            variant: :destructive,
            form: { data: { turbo_confirm: "#{t("notice.are_you_sure")} #{t("common.cannot_be_undone")}" } }
          ) do %>
            <span><%= t("common.disconnect") %></span>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="text-sm text-gray-500 py-4">
        <span><%= t("common.no_shared_organizations") %></span>
      </div>
    <% end %>
  </div>
</div>
